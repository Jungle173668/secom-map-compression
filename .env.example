# Choose LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: model overrides
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-6

# LLMLingua compression model (small GPT-2 works fine for token filtering)
LLMLINGUA_MODEL=openai-community/gpt2

# Path to LoCoMo dataset JSON (after cloning snap-research/locomo)
LOCOMO_PATH=locomo/data/locomo10.json
